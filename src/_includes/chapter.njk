---
layout: base.njk
---
{#
  chapter.njk
  Layout for novel chapter pages. Extends base.njk.

  Expected front matter fields (from PROJECT_BRIEFING.md schema):
    title, chapter_number, arc, publication_date, summary, wiki_links

  Notes:
    - publication_date is formatted using the `readableDate` filter
    - wiki_links boolean controls whether the wikiLinks transform renders
      real <a> tags; client-side CSS + reader.js handle show/hide at runtime
    - Reader controls (font size, wiki links, theme) are fixed-position and
      appear on all chapter pages; all state is persisted in localStorage
#}

{# Reader controls — floating pill, bottom-right. JS in reader.js drives state. #}
<div class="reader-controls" role="toolbar" aria-label="Reading preferences">
  <button class="reader-controls__btn reader-controls__btn--sm" data-font-size-btn="sm" aria-pressed="false" aria-label="Small text size">A</button>
  <button class="reader-controls__btn reader-controls__btn--md" data-font-size-btn="md" aria-pressed="false" aria-label="Medium text size">A</button>
  <button class="reader-controls__btn reader-controls__btn--lg" data-font-size-btn="lg" aria-pressed="false" aria-label="Large text size">A</button>
  {% if wiki_links %}
  <div class="reader-controls__divider" aria-hidden="true"></div>
  <button class="reader-controls__btn reader-controls__btn--wiki" id="wiki-links-toggle" aria-pressed="true" aria-label="Toggle wiki links">Links</button>
  {% endif %}
  <div class="reader-controls__divider" aria-hidden="true"></div>
  <button class="reader-controls__theme-btn" id="theme-toggle" aria-label="Toggle theme">Dark</button>
</div>

<article class="chapter" data-wiki-links="{{ wiki_links }}">

  <header class="chapter__header">

    {% if arc %}
    <p class="chapter__arc">{{ arc }}</p>
    {% endif %}

    <p class="chapter__number">Chapter {{ chapter_number }}</p>
    <h1 class="chapter__title">{{ title }}</h1>

    {% if publication_date %}
    <p class="chapter__date">{{ publication_date | readableDate }}</p>
    {% endif %}

    {% if summary %}
    <p class="chapter__summary">{{ summary }}</p>
    {% endif %}

  </header>

  <section class="chapter__body">
    {{ content | safe }}
  </section>

  <nav class="chapter__pagination">
    {# Future: previous / next chapter navigation links #}
  </nav>

</article>
