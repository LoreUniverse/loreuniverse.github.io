{#
  base.njk
  Root layout — wraps every page on the site.
  All other templates extend this one using `layout: base.njk` in their
  front matter or directory data file.

  Available variables:
    title       — page title, set in each page's front matter
    content     — the rendered HTML output of the child template, injected
                  into the <main> block via the `safe` filter (which tells
                  Nunjucks not to escape the HTML)
    navigation  — global nav data from src/_data/navigation.js
    site        — global site data from src/_data/site.js
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or name }} | Lore Universe</title>
  {# wiki-links-default seeds the reader's first-visit wiki link preference.
     Subsequent visits use the value stored in localStorage instead. #}
  <meta name="wiki-links-default" content="{{ config.wikiLinksVisible }}">
  <link rel="stylesheet" href="/assets/css/reader.css">

  {#
    Anti-FOUC: apply saved theme, font-size, and wiki-link visibility before
    first paint so the page never flickers on load.
    Must run synchronously in <head>. The meta tag above is parsed before
    this script runs, so it is safe to read here.
  #}
  <script>
    (function () {
      var t = localStorage.getItem('lr-theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      var f = localStorage.getItem('lr-font-size') || 'md';
      document.documentElement.dataset.theme    = t;
      document.documentElement.dataset.fontSize = f;

      var storedWiki = localStorage.getItem('lr-wiki-links');
      if (storedWiki !== null) {
        if (storedWiki === 'false') document.documentElement.dataset.wikiLinks = 'hidden';
      } else {
        var meta = document.querySelector('meta[name="wiki-links-default"]');
        if (meta && meta.content === 'false') {
          document.documentElement.dataset.wikiLinks = 'hidden';
        }
      }
    })();
  </script>
</head>
<body>

  <header>
    <nav aria-label="Primary">
      <ul class="nav__list">
        {% for item in navigation %}
          <li class="nav__item">
            <a class="nav__link" href="{{ item.href }}">{{ item.label }}</a>

            {% if item.submenu %}
              {#
                Chevron button is a sibling of the label link, NOT a wrapper
                around it. This keeps the label as a real navigable link
                while the chevron is the dedicated dropdown trigger.
              #}
              <button
                class="nav__toggle"
                type="button"
                aria-expanded="false"
                aria-controls="nav-submenu-{{ loop.index }}"
                aria-label="Toggle {{ item.label }} submenu"
                data-nav-toggle
              >▾</button>

              <ul
                id="nav-submenu-{{ loop.index }}"
                class="nav__submenu"
                hidden
              >
                {% for sub in item.submenu %}
                  <li class="nav__subitem">
                    <a class="nav__sublink" href="{{ sub.href }}">{{ sub.label }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <p>&copy; Lore Universe. All rights reserved.</p>
  </footer>

  {#
    Dropdown behavior. Click chevron to toggle, click outside to close,
    Escape to close. Click-to-open (not hover) so touch devices work.
  #}
  <script>
    (function () {
      const toggles = document.querySelectorAll('[data-nav-toggle]');

      function closeAll() {
        toggles.forEach(t => {
          t.setAttribute('aria-expanded', 'false');
          const submenu = t.nextElementSibling;
          if (submenu) submenu.hidden = true;
        });
      }

      toggles.forEach(toggle => {
        toggle.addEventListener('click', e => {
          e.stopPropagation();
          const isOpen = toggle.getAttribute('aria-expanded') === 'true';
          closeAll();
          if (!isOpen) {
            toggle.setAttribute('aria-expanded', 'true');
            toggle.nextElementSibling.hidden = false;
          }
        });
      });

      document.addEventListener('click', e => {
        if (!e.target.closest('.nav__item')) closeAll();
      });

      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeAll();
      });
    })();
  </script>

  <script src="/assets/js/reader.js" defer></script>

</body>
</html>
