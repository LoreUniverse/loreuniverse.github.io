{#
  base.njk
  Root layout — wraps every page on the site.
  All other templates extend this one using `layout: base.njk` in their
  front matter or directory data file.

  Available variables:
    title       — page title, set in each page's front matter
    content     — the rendered HTML output of the child template, injected
                  into the <main> block via the `safe` filter (which tells
                  Nunjucks not to escape the HTML)
    navigation  — global nav data from src/_data/navigation.js
    site        — global site data from src/_data/site.js
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or name }} | Lore Universe</title>
  {# Uncomment the line below when a stylesheet is added during the design phase #}
  {# <link rel="stylesheet" href="/assets/css/styles.css"> #}

  {#
    Minimum dropdown styling. This is intentionally bare — proper visual
    design is deferred. These rules exist only to make the dropdown function:
    submenus must be absolutely positioned so they overlay content rather
    than push it down, and the hidden attribute must reliably hide them.
  #}
  <style>
    .nav__list { list-style: none; padding: 0; margin: 0; display: flex; gap: 1rem; }
    .nav__item { position: relative; }
    .nav__toggle {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0 0.25rem;
      font: inherit;
    }
    .nav__submenu {
      position: absolute;
      top: 100%;
      left: 0;
      list-style: none;
      padding: 0.5rem;
      margin: 0;
      min-width: 8rem;
      background: #fff;
      border: 1px solid #ccc;
      z-index: 10;
    }
    .nav__submenu[hidden] { display: none; }
    .nav__sublink { display: block; padding: 0.25rem 0; }
  </style>
</head>
<body>

  <header>
    <nav aria-label="Primary">
      <ul class="nav__list">
        {% for item in navigation %}
          <li class="nav__item">
            <a class="nav__link" href="{{ item.href }}">{{ item.label }}</a>

            {% if item.submenu %}
              {#
                Chevron button is a sibling of the label link, NOT a wrapper
                around it. This keeps the label as a real navigable link
                while the chevron is the dedicated dropdown trigger.
              #}
              <button
                class="nav__toggle"
                type="button"
                aria-expanded="false"
                aria-controls="nav-submenu-{{ loop.index }}"
                aria-label="Toggle {{ item.label }} submenu"
                data-nav-toggle
              >▾</button>

              <ul
                id="nav-submenu-{{ loop.index }}"
                class="nav__submenu"
                hidden
              >
                {% for sub in item.submenu %}
                  <li class="nav__subitem">
                    <a class="nav__sublink" href="{{ sub.href }}">{{ sub.label }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <p>&copy; Lore Universe. All rights reserved.</p>
  </footer>

  {#
    Dropdown behavior. Click chevron to toggle, click outside to close,
    Escape to close. Click-to-open (not hover) so touch devices work.
    Kept inline because there is no /assets/js/ folder yet — when one is
    added during the design phase, this should move into a script file.
  #}
  <script>
    (function () {
      const toggles = document.querySelectorAll('[data-nav-toggle]');

      function closeAll() {
        toggles.forEach(t => {
          t.setAttribute('aria-expanded', 'false');
          const submenu = t.nextElementSibling;
          if (submenu) submenu.hidden = true;
        });
      }

      toggles.forEach(toggle => {
        toggle.addEventListener('click', e => {
          e.stopPropagation();
          const isOpen = toggle.getAttribute('aria-expanded') === 'true';
          closeAll();
          if (!isOpen) {
            toggle.setAttribute('aria-expanded', 'true');
            toggle.nextElementSibling.hidden = false;
          }
        });
      });

      // Click anywhere outside a submenu closes all dropdowns
      document.addEventListener('click', e => {
        if (!e.target.closest('.nav__item')) closeAll();
      });

      // Escape closes all dropdowns
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeAll();
      });
    })();
  </script>

</body>
</html>
