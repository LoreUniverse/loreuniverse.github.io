{#
  wiki-entry.njk — V2
  Fallback layout for wiki entry pages that don't have a
  more specific per-category template (character.njk, etc.).
  Extends base.njk.

  Expected front matter: name
#}
---
layout: base.njk
---

<div class="wiki-entry-page">
  <div class="wiki-entry-page-inner">

    <a class="wiki-entry-page-back" href="/wiki/">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Wiki
    </a>

    <div class="wiki-entry-page-badge">Entry</div>

    <h1 class="wiki-entry-page-title">{{ name }}</h1>
    <button class="wiki-favorite-btn" id="wiki-fav-btn"
      data-slug="{{ page.fileSlug }}"
      aria-label="Add to favorites" aria-pressed="false">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    </button>

    <div class="wiki-entry-page-prose">
      {{ content | safe }}
    </div>

  </div>
</div>

<script type="module">
import { isFavorited, toggleFavorite } from '/assets/js/progress.js';
const btn = document.getElementById('wiki-fav-btn');
const category = '{{ page.url }}'.split('/')[2];
const slug = btn.dataset.slug;
function setActive(active) {
  btn.setAttribute('aria-pressed', String(active));
  btn.classList.toggle('wiki-favorite-btn--active', active);
  btn.setAttribute('aria-label', active ? 'Remove from favorites' : 'Add to favorites');
}
setActive(isFavorited(category, slug));
document.addEventListener('progress-ready', () => setActive(isFavorited(category, slug)), { once: true });
btn.addEventListener('click', async () => {
  const { favorited } = await toggleFavorite(category, slug);
  setActive(favorited);
});
</script>
