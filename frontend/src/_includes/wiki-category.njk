---
layout: base.njk
---
{#
  wiki-category.njk — V2
  Shared layout for all six wiki category listing pages.
  Extends base.njk.

  Required front matter on the category index.md:
    title:        "Characters"   (display name)
    category_key: "characters"   (matches wiki.byCategory key and folder name)
    layout:       "wiki-category.njk"
    permalink:    "/wiki/characters/"

  Primary data source: wiki.byCategory[category_key] (API-backed).
  Fallback: Eleventy collections (characters, loreTraits, mechanics, etc.)
  if the API is unavailable at build time.
#}

{# Try API data first, fall back to Eleventy collections #}
{% set entries = wiki.byCategory[category_key] %}

{% if not entries or not entries.length %}
  {# Map category_key to the correct Eleventy collection #}
  {% if category_key == 'characters' %}
    {% set collectionItems = collections.characters %}
  {% elif category_key == 'lore-traits' %}
    {% set collectionItems = collections.loreTraits %}
  {% elif category_key == 'mechanics' %}
    {% set collectionItems = collections.mechanics %}
  {% elif category_key == 'locations' %}
    {% set collectionItems = collections.locations %}
  {% elif category_key == 'factions' %}
    {% set collectionItems = collections.factions %}
  {% elif category_key == 'lore' %}
    {% set collectionItems = collections.lore %}
  {% endif %}
{% endif %}

{% set entryCount = entries.length if (entries and entries.length) else (collectionItems.length if collectionItems else 0) %}

<div class="wiki-category">
  <div class="container">

    <div class="wiki-category-header">
      <a class="wiki-category-back" href="/wiki/">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Wiki
      </a>
      <h1 class="wiki-category-title">{{ title }}</h1>
      <p class="wiki-category-count">
        {% if entryCount %}{{ entryCount }} {% if entryCount == 1 %}entry{% else %}entries{% endif %}{% else %}No entries yet{% endif %}
      </p>
    </div>

    {% if entries and entries.length %}
    {# API data path #}
    <div class="wiki-entry-grid">
      {% for entry in entries %}
      <a class="wiki-entry-card" href="{{ site.modules.wiki.root }}/{{ category_key }}/{{ entry.slug }}/">
        <span class="wiki-entry-card-badge">{{ title | truncate(12, true, '') }}</span>
        <p class="wiki-entry-card-name">{{ entry.name }}</p>
        {% if entry.description %}
        <p class="wiki-entry-card-desc">{{ entry.description | truncate(120) }}</p>
        {% endif %}
      </a>
      {% endfor %}
    </div>

    {% elif collectionItems and collectionItems.length %}
    {# Eleventy collection fallback — collections already exclude index pages #}
    <div class="wiki-entry-grid">
      {% for item in collectionItems %}
      <a class="wiki-entry-card" href="{{ item.url }}">
        <span class="wiki-entry-card-badge">{{ title | truncate(12, true, '') }}</span>
        <p class="wiki-entry-card-name">{{ item.data.name }}</p>
        {% if item.data.summary %}
        <p class="wiki-entry-card-desc">{{ item.data.summary | truncate(120) }}</p>
        {% endif %}
      </a>
      {% endfor %}
    </div>

    {% else %}
    <div class="wiki-empty">
      <p class="wiki-empty-text">No entries yet.</p>
    </div>
    {% endif %}

  </div>
</div>
