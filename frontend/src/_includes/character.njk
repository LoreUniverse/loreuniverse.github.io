---
layout: base.njk
---
{#
  character.njk
  Layout for Character wiki entries. Extends base.njk.

  Renders all structured front matter fields defined in the Characters schema,
  followed by the full Markdown body (background and character description).

  Expected front matter fields (from PROJECT_BRIEFING.md schema):
    name, status, species, factions, home_location, lore_traits,
    skills, equipment, notes (internal — not rendered)
#}

<article class="wiki-entry wiki-entry--character">

  <header class="wiki-entry__header">
    <h1>{{ name }}</h1>
    <p class="wiki-entry__category">Character</p>
    <button class="wiki-favorite-btn" id="wiki-fav-btn"
      data-category="characters" data-slug="{{ page.fileSlug }}"
      aria-label="Add to favorites" aria-pressed="false">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    </button>
  </header>

  <section class="wiki-entry__meta">

    {% if status %}
    <div class="wiki-entry__field">
      <span class="wiki-entry__label">Status</span>
      <span class="wiki-entry__value">{{ status }}</span>
    </div>
    {% endif %}

    {% if species %}
    <div class="wiki-entry__field">
      <span class="wiki-entry__label">Species</span>
      <span class="wiki-entry__value">{{ species }}</span>
    </div>
    {% endif %}

    {% if home_location %}
    <div class="wiki-entry__field">
      <span class="wiki-entry__label">Home Location</span>
      <span class="wiki-entry__value">
        <a href="{{ site.modules.wiki.root }}/locations/{{ home_location }}/">{{ home_location }}</a>
      </span>
    </div>
    {% endif %}

    {% if factions and factions.length %}
    <div class="wiki-entry__field">
      <span class="wiki-entry__label">Factions</span>
      <ul class="wiki-entry__list">
        {% for faction in factions %}
        <li><a href="{{ site.modules.wiki.root }}/factions/{{ faction }}/">{{ faction }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if lore_traits and lore_traits.length %}
    <div class="wiki-entry__field">
      <span class="wiki-entry__label">Lore Traits</span>
      <ul class="wiki-entry__list">
        {% for trait in lore_traits %}
        <li><a href="{{ site.modules.wiki.root }}/lore-traits/{{ trait }}/">{{ trait }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if skills and skills.length %}
    <div class="wiki-entry__field">
      <span class="wiki-entry__label">Skills</span>
      <ul class="wiki-entry__list">
        {% for skill in skills %}
        <li>{{ skill }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if equipment and equipment.length %}
    <div class="wiki-entry__field">
      <span class="wiki-entry__label">Equipment</span>
      <ul class="wiki-entry__list">
        {% for item in equipment %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

  </section>

  {# The Markdown body — full background and character description #}
  <section class="wiki-entry__body">
    {{ content | safe }}
  </section>

</article>

<script type="module">
import { isFavorited, toggleFavorite } from '/assets/js/progress.js';
const btn = document.getElementById('wiki-fav-btn');
const { category, slug } = btn.dataset;
function setActive(active) {
  btn.setAttribute('aria-pressed', String(active));
  btn.classList.toggle('wiki-favorite-btn--active', active);
  btn.setAttribute('aria-label', active ? 'Remove from favorites' : 'Add to favorites');
}
setActive(isFavorited(category, slug));
document.addEventListener('progress-ready', () => setActive(isFavorited(category, slug)), { once: true });
btn.addEventListener('click', async () => {
  const { favorited } = await toggleFavorite(category, slug);
  setActive(favorited);
});
</script>
