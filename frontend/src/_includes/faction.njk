---
layout: base.njk
---
{#
  faction.njk
  Layout for Faction wiki entries. Extends base.njk.

  Expected front matter fields (from PROJECT_BRIEFING.md schema):
    name, type, alignment, notable_characters, base_location, lore
#}

<article class="wiki-entry wiki-entry--faction">

  <header class="wiki-entry__header">
    <h1>{{ name }}</h1>
    <p class="wiki-entry__category">Faction</p>
    <button class="wiki-favorite-btn" id="wiki-fav-btn"
      data-category="factions" data-slug="{{ page.fileSlug }}"
      aria-label="Add to favorites" aria-pressed="false">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    </button>
  </header>

  <section class="wiki-entry__meta">

    {% if type %}
    <div class="wiki-entry__field">
      <span class="wiki-entry__label">Type</span>
      <span class="wiki-entry__value">{{ type }}</span>
    </div>
    {% endif %}

    {% if alignment %}
    <div class="wiki-entry__field">
      <span class="wiki-entry__label">Alignment</span>
      <span class="wiki-entry__value">{{ alignment }}</span>
    </div>
    {% endif %}

    {% if base_location %}
    <div class="wiki-entry__field">
      <span class="wiki-entry__label">Base Location</span>
      <span class="wiki-entry__value">
        <a href="{{ site.modules.wiki.root }}/locations/{{ base_location }}/">{{ base_location }}</a>
      </span>
    </div>
    {% endif %}

    {% if notable_characters and notable_characters.length %}
    <div class="wiki-entry__field">
      <span class="wiki-entry__label">Notable Characters</span>
      <ul class="wiki-entry__list">
        {% for character in notable_characters %}
        <li><a href="{{ site.modules.wiki.root }}/characters/{{ character }}/">{{ character }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if lore and lore.length %}
    <div class="wiki-entry__field">
      <span class="wiki-entry__label">Related Lore</span>
      <ul class="wiki-entry__list">
        {% for entry in lore %}
        <li><a href="{{ site.modules.wiki.root }}/lore/{{ entry }}/">{{ entry }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

  </section>

  {# The Markdown body — full description of the faction #}
  <section class="wiki-entry__body">
    {{ content | safe }}
  </section>

</article>

<script type="module">
import { isFavorited, toggleFavorite } from '/assets/js/progress.js';
const btn = document.getElementById('wiki-fav-btn');
const { category, slug } = btn.dataset;
function setActive(active) {
  btn.setAttribute('aria-pressed', String(active));
  btn.classList.toggle('wiki-favorite-btn--active', active);
  btn.setAttribute('aria-label', active ? 'Remove from favorites' : 'Add to favorites');
}
setActive(isFavorited(category, slug));
document.addEventListener('progress-ready', () => setActive(isFavorited(category, slug)), { once: true });
btn.addEventListener('click', async () => {
  const { favorited } = await toggleFavorite(category, slug);
  setActive(favorited);
});
</script>
